
# 1. CREATE LIST
fruits = ["Apple", "Banana", "Mango"]
print("Initial List:", fruits)


# 2. ACCESS ELEMENTS
print("First Fruit:", fruits[0])
print("Second Fruit:", fruits[1])


# 3. UPDATE LIST ITEM
fruits[1] = "Orange"
print("After Update:", fruits)


# 4. ADD ELEMENTS (append)
fruits.append("Grapes")
print("After Append:", fruits)


# 5. INSERT AT POSITION
fruits.insert(1, "Pineapple")
print("After Insert:", fruits)


# 6. REMOVE ELEMENT
fruits.remove("Mango")
print("After Remove:", fruits)


# 7. POP ELEMENT (last item)
removed_item = fruits.pop()
print("Popped Item:", removed_item)
print("After Pop:", fruits)


# 8. LENGTH OF LIST
print("Length:", len(fruits))


# 9. LOOP THROUGH LIST
print("Looping List:")
for fruit in fruits:
    print(fruit)


# 10. CHECK ITEM EXISTS
if "Apple" in fruits:
    print("Apple is in list")


# 11. SORT LIST
numbers = [5, 2, 9, 1, 7]
numbers.sort()
print("Sorted Numbers:", numbers)


# 12. REVERSE LIST
numbers.reverse()
print("Reversed Numbers:", numbers)


# 13. COPY LIST
copy_list = fruits.copy()
print("Copied List:", copy_list)


# 14. CLEAR LIST
temp = [1, 2, 3]
temp.clear()
print("Cleared List:", temp)


# 15. LIST COMPREHENSION
squares = [x * x for x in range(1, 6)]
print("Squares:", squares)


# 16. REAL TIME EXAMPLE (STUDENT LIST SYSTEM)
students = []

# ADD STUDENTS
students.append("Ravi")
students.append("Ram")
students.append("Krishna")

print("Students:", students)

# REMOVE STUDENT
students.remove("Ram")
print("After Removal:", students)

# SEARCH STUDENT
name = "Ravi"

if name in students:
    print(name, "is present")
else:
    print(name, "not found"))
