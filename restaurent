<!DOCTYPE html>
<html>
<head>
  <title>Restaurant UI</title>

  <style>
    body {
      font-family: Georgia;
      background: #111;
      color: white;
      text-align: center;
    }

    select {
      padding: 10px;
      margin-top: 20px;
    }

    .menu-box {
      margin-top: 20px;
      padding: 20px;
      border: 2px solid gold;
      display: none;
      width: 300px;
      margin-left: auto;
      margin-right: auto;
    }

    .menu-item {
      background: #333;
      margin: 5px;
      padding: 10px;
    }

    button {
      margin-top: 10px;
      padding: 10px;
      background: darkred;
      color: white;
      border: none;
    }
  </style>
</head>

<body>

<h1>🍽️ Restaurant Selector</h1>

<select onchange="loadMenu()" id="restaurant">
  <option value="">Select</option>
  <option value="A">Hotel A</option>
  <option value="B">Hotel B</option>
</select>

<div id="menu" class="menu-box">
  <h3 id="title"></h3>

  <div class="menu-item">🍛 Biryani - ₹180</div>
  <div class="menu-item">🍔 Burger - ₹120</div>

  <button onclick="order()">Order</button>

  <p id="msg"></p>
</div>

<script>
function loadMenu() {
  let r = document.getElementById("restaurant").value;
  let menu = document.getElementById("menu");
  let title = document.getElementById("title");

  if (r === "A") {
    title.innerText = "Hotel A Menu";
  } else if (r === "B") {
    title.innerText = "Hotel B Menu";
  } else {
    menu.style.display = "none";
    return;
  }

  menu.style.display = "block";
}

function order() {
  document.getElementById("msg").innerText =
    "Order placed successfully!";
}
</script>

</body>
</html>
